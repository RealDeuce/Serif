// lcd.nib - LCD hardware base-select driver
//
// The LCD controller scans memory starting at the raw selector written
// to PORT_LCD_BASE. MAME and Dreamulator model the byte as selector << 9.

use "platform.nif";
use "spine.nif";
use "lookup.nif";

// ---------------------------------------------------------------------------
// API function offsets (pre-multiplied)
// ---------------------------------------------------------------------------

pub const LCD_SET_BASE = 0;  // AL = raw LCD base selector

const LCD_API_SIZE = 0x04;
const LCD_VERSION  = 1;

// ---------------------------------------------------------------------------
// State
// ---------------------------------------------------------------------------

at(0x0000:0x070C);
pub u8 lcd_base_selector;
u8 lcd_base_pad;
pub u16 lcd_fb_offset;
end at;

// ---------------------------------------------------------------------------
// API functions
// ---------------------------------------------------------------------------

fn api far lcd_set_base(selector: u8 in AL) ds(0x0000) clobbers(FLAGS) {
    lcd_base_selector := selector;
    lcd_fb_offset := zero_extend(selector) << 9;
    port_out(PORT_LCD_BASE, selector);
}

// ---------------------------------------------------------------------------
// Jump table
// ---------------------------------------------------------------------------

pub far32[1] lcd_table = {@lcd_set_base};

// ---------------------------------------------------------------------------
// Init
// ---------------------------------------------------------------------------

pub fn lcd_init() {
    lcd_set_base(LCD_DEFAULT_SELECTOR);
    register(DEV_LCD, LCD_VERSION, @lcd_table, LCD_API_SIZE);
}
