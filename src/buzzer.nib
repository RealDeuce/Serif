// buzzer.nib — Tone generator driver
//
// Controls the gate array's buzzer hardware via ports 0x50–0x52.
// The tone frequency is set by a 16-bit divisor written as two
// bytes (low, high). The buzzer is enabled/disabled separately.
//
// No IRQs — purely output-driven.

use "platform.nif";
use "spine.nif";
use "lookup.nif";

// ---------------------------------------------------------------------------
// API function offsets (pre-multiplied)
// ---------------------------------------------------------------------------

pub const BUZZER_API_TONE = 0;  // set tone divisor (AX = divisor)
pub const BUZZER_API_ON   = 1;  // enable buzzer output
pub const BUZZER_API_OFF  = 2;  // disable buzzer output

const BUZZER_API_SIZE = 0x0C;  // 3 entries × 4 bytes
const BUZZER_VERSION  = 1;

// ---------------------------------------------------------------------------
// API functions
// ---------------------------------------------------------------------------

fn api far tone(divisor: u16 in AX) ds(none) clobbers(FLAGS) {
    port_out16(PORT_BUZZER_LO, divisor);
}

fn api far on() ds(none) clobbers(FLAGS) {
    port_out(PORT_BUZZER_EN, BUZZER_ON);
}

fn api far off() ds(none) clobbers(FLAGS) {
    port_out(PORT_BUZZER_EN, BUZZER_OFF);
}

// ---------------------------------------------------------------------------
// Jump table (must follow function definitions)
// ---------------------------------------------------------------------------

pub far32[3] buzzer_table = {@tone, @on, @off};

// ---------------------------------------------------------------------------
// Init
// ---------------------------------------------------------------------------

pub fn buzzer_init() {
    // Silence buzzer
    port_out(PORT_BUZZER_EN, BUZZER_OFF);

    // Register with service locator
    register(DEV_BUZZER, BUZZER_VERSION, @buzzer_table, BUZZER_API_SIZE);
}
