// ---------------------------------------------------------------------------
// API: generic 1bpp blit operations
//
// desc: far pointer to FbBlit. Source rows are MSB-first, with stride
// bytes between rows. Width is in pixels.
// ---------------------------------------------------------------------------

fn api far fb_blit_copy_inv(desc: far32 in ES:SI)
    ds(0x0000) clobbers(AX, CX, DX, BX, SI, DI, ES, FLAGS) {
    const u16 src_row = [ES:SI + FB_BUF_SRC_OFF];
    const u16 src_stride = [ES:SI + FB_BUF_STRIDE];
    const u16 width = [ES:SI + FB_BUF_WIDTH];
    const u8 height = [ES:SI + FB_BUF_HEIGHT];
    const u16 dst_x = [ES:SI + FB_BLIT_DST_X];
    const u8 dst_y = [ES:SI + FB_BLIT_DST_Y];
    const seg src_seg = [ES:SI + FB_BUF_SRC_SEG] as (seg);
    const u16 shift = dst_x & 0x07;
    const u16 dst_row = fb_start_index(dst_x, dst_y);
    const u16 target = fb_copy_inv_dispatch[shift];
    target as fb_copy_inv_s0(src_seg, src_row, src_stride,
                             width, height, dst_row);
}

fn api far fb_blit_or(desc: far32 in ES:SI)
    ds(0x0000) clobbers(AX, CX, DX, BX, SI, DI, ES, FLAGS) {
    const u16 src_row = [ES:SI + FB_BUF_SRC_OFF];
    const u16 src_stride = [ES:SI + FB_BUF_STRIDE];
    const u16 width = [ES:SI + FB_BUF_WIDTH];
    const u8 height = [ES:SI + FB_BUF_HEIGHT];
    const u16 dst_x = [ES:SI + FB_BLIT_DST_X];
    const u8 dst_y = [ES:SI + FB_BLIT_DST_Y];
    const seg src_seg = [ES:SI + FB_BUF_SRC_SEG] as (seg);
    const u16 shift = dst_x & 0x07;
    const u16 dst_row = fb_start_index(dst_x, dst_y);
    const u16 target = fb_or_dispatch[shift];
    target as fb_or_s0(src_seg, src_row, src_stride,
                       width, height, dst_row);
}

fn api far fb_blit_xor(desc: far32 in ES:SI)
    ds(0x0000) clobbers(AX, CX, DX, BX, SI, DI, ES, FLAGS) {
    const u16 src_row = [ES:SI + FB_BUF_SRC_OFF];
    const u16 src_stride = [ES:SI + FB_BUF_STRIDE];
    const u16 width = [ES:SI + FB_BUF_WIDTH];
    const u8 height = [ES:SI + FB_BUF_HEIGHT];
    const u16 dst_x = [ES:SI + FB_BLIT_DST_X];
    const u8 dst_y = [ES:SI + FB_BLIT_DST_Y];
    const seg src_seg = [ES:SI + FB_BUF_SRC_SEG] as (seg);
    const u16 shift = dst_x & 0x07;
    const u16 dst_row = fb_start_index(dst_x, dst_y);
    const u16 target = fb_xor_dispatch[shift];
    target as fb_xor_s0(src_seg, src_row, src_stride,
                        width, height, dst_row);
}

fn api far fb_blit_and(desc: far32 in ES:SI)
    ds(0x0000) clobbers(AX, CX, DX, BX, SI, DI, ES, FLAGS) {
    const u16 src_row = [ES:SI + FB_BUF_SRC_OFF];
    const u16 src_stride = [ES:SI + FB_BUF_STRIDE];
    const u16 width = [ES:SI + FB_BUF_WIDTH];
    const u8 height = [ES:SI + FB_BUF_HEIGHT];
    const u16 dst_x = [ES:SI + FB_BLIT_DST_X];
    const u8 dst_y = [ES:SI + FB_BLIT_DST_Y];
    const seg src_seg = [ES:SI + FB_BUF_SRC_SEG] as (seg);
    const u16 shift = dst_x & 0x07;
    const u16 dst_row = fb_start_index(dst_x, dst_y);
    const u16 target = fb_and_dispatch[shift];
    target as fb_and_s0(src_seg, src_row, src_stride,
                        width, height, dst_row);
}

fn api far fb_blit_not(desc: far32 in ES:SI)
    ds(0x0000) clobbers(AX, CX, DX, BX, SI, DI, ES, FLAGS) {
    const u16 width = [ES:SI + FB_BUF_WIDTH];
    const u8 height = [ES:SI + FB_BUF_HEIGHT];
    const u16 dst_x = [ES:SI + FB_BLIT_DST_X];
    const u8 dst_y = [ES:SI + FB_BLIT_DST_Y];
    const u16 shift = dst_x & 0x07;
    const u16 dst_row = fb_start_index(dst_x, dst_y);
    const u16 target = fb_not_dispatch[shift];
    target as fb_not_s0(width, height, dst_row);
}

// ---------------------------------------------------------------------------
// Jump table
// ---------------------------------------------------------------------------

pub far32[7] fb_table = {
    @fb_clear,
    @fb_blit_copy,
    @fb_blit_copy_inv,
    @fb_blit_or,
    @fb_blit_xor,
    @fb_blit_and,
    @fb_blit_not
};

// ---------------------------------------------------------------------------
// Init
// ---------------------------------------------------------------------------

pub fn fb_init() {
    fb_clear();
    register(DEV_FB, FB_VERSION, @fb_table, FB_API_SIZE);
}
