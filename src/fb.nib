                   height: u8 in stack, start_dst_row: u16) {
    u16 src_row = start_src_row;
    u16 dst_row = start_dst_row;
    u8 rows_left = height;

and_s6_tail_row_loop:
    if (rows_left == 0) {
        return;
    }
    u16 src_off = src_row;
    u16 idx = dst_row;

    const u8 wmask = 0xFF << (8 - tail_bits);
    const u8 tail_lo_mask = wmask >> 6;
    const u8 tail_hi_mask = wmask << 2;
    const u8 tail_byte = [ES:src_off] & wmask;
    [idx] := [idx] & ((tail_byte >> 6) | ~tail_lo_mask);
    [idx + 1] := [idx + 1] & ((tail_byte << 2) | ~tail_hi_mask);

    src_row := src_row + src_stride;
    dst_row := dst_row + LCD_SCAN_STRIDE;
    rows_left := rows_left - 1;
    goto and_s6_tail_row_loop;
}
fn api fb_and_s6(src_seg: seg in ES, start_src_row: u16 in AX,
              src_stride: u16 in stack, width: u16 in stack,
              height: u8 in stack, start_dst_row: u16 in BX)
              clobbers(AX, CX, DX, BX, SI, DI, ES, FLAGS) {
    const u16 full_bytes = width >> 3;
    const u8 tail_bits = (width & 0x07) as (u8);

    if (full_bytes != 0) {
        fb_and_s6_full(src_seg, start_src_row, src_stride,
                        full_bytes, height, start_dst_row);
    }
    if (tail_bits != 0) {
        fb_and_s6_tail(src_seg, start_src_row + full_bytes, src_stride,
                        tail_bits, height, start_dst_row + full_bytes);
    }
}
fn fb_and_s7_full(src_seg: seg in ES, start_src_row: u16,
                   src_stride: u16 in stack, full_bytes: u16 in stack,
                   height: u8 in stack, start_dst_row: u16) {
    u16 src_row = start_src_row;
    u16 dst_row = start_dst_row;
    u8 rows_left = height;

and_s7_full_row_loop:
    if (rows_left == 0) {
        return;
    }
    u16 src_off = src_row;
    u16 idx = dst_row;
    u16 count = full_bytes;

and_s7_full_loop:
    const u8 sbyte = [ES:src_off];
    const u8 src_lo = sbyte >> 7;
    const u8 src_hi = sbyte << 1;
    [idx] := [idx] & (src_lo | 0xFE);
    [idx + 1] := [idx + 1] & (src_hi | 0x01);

    src_off := src_off + 1;
    idx := idx + 1;
    count := count - 1;
    if (count != 0) {
        goto and_s7_full_loop;
    }

and_s7_full_next_row:
    src_row := src_row + src_stride;
    dst_row := dst_row + LCD_SCAN_STRIDE;
    rows_left := rows_left - 1;
    goto and_s7_full_row_loop;
}
fn fb_and_s7_tail(src_seg: seg in ES, start_src_row: u16,
                   src_stride: u16 in stack, tail_bits: u8 in stack,
                   height: u8 in stack, start_dst_row: u16) {
    u16 src_row = start_src_row;
    u16 dst_row = start_dst_row;
    u8 rows_left = height;

and_s7_tail_row_loop:
    if (rows_left == 0) {
        return;
    }
    u16 src_off = src_row;
    u16 idx = dst_row;

    const u8 wmask = 0xFF << (8 - tail_bits);
    const u8 tail_lo_mask = wmask >> 7;
    const u8 tail_hi_mask = wmask << 1;
    const u8 tail_byte = [ES:src_off] & wmask;
    [idx] := [idx] & ((tail_byte >> 7) | ~tail_lo_mask);
    [idx + 1] := [idx + 1] & ((tail_byte << 1) | ~tail_hi_mask);

    src_row := src_row + src_stride;
    dst_row := dst_row + LCD_SCAN_STRIDE;
    rows_left := rows_left - 1;
    goto and_s7_tail_row_loop;
}
fn api fb_and_s7(src_seg: seg in ES, start_src_row: u16 in AX,
              src_stride: u16 in stack, width: u16 in stack,
              height: u8 in stack, start_dst_row: u16 in BX)
              clobbers(AX, CX, DX, BX, SI, DI, ES, FLAGS) {
    const u16 full_bytes = width >> 3;
    const u8 tail_bits = (width & 0x07) as (u8);

    if (full_bytes != 0) {
        fb_and_s7_full(src_seg, start_src_row, src_stride,
                        full_bytes, height, start_dst_row);
    }
    if (tail_bits != 0) {
        fb_and_s7_tail(src_seg, start_src_row + full_bytes, src_stride,
                        tail_bits, height, start_dst_row + full_bytes);
    }
}
