fn fb_copy_s7_full(src_seg: seg in ES, start_src_row: u16,
                   src_stride: u16 in stack, full_bytes: u16 in stack,
                   height: u8 in stack, start_dst_row: u16) {
    u16 src_row = start_src_row;
    u16 dst_row = start_dst_row;
    u8 rows_left = height;

copy_s7_fast_row_loop:
    if (rows_left == 0) {
        return;
    }
    u16 src_off = src_row;
    u16 idx = dst_row;
    u16 count = full_bytes;

copy_s7_fast_full_loop:
    const u8 sbyte = [ES:src_off];
    const u8 src_lo = sbyte >> 7;
    const u8 src_hi = sbyte << 1;
    [idx] := ([idx] & 0xFE) | src_lo;
    [idx + 1] := ([idx + 1] & 0x01) | src_hi;
    src_off := src_off + 1;
    idx := idx + 1;
    count := count - 1;
    if (count != 0) {
        goto copy_s7_fast_full_loop;
    }

copy_s7_fast_next_row:
    src_row := src_row + src_stride;
    dst_row := dst_row + LCD_SCAN_STRIDE;
    rows_left := rows_left - 1;
    goto copy_s7_fast_row_loop;
}

fn fb_copy_s7_tail(src_seg: seg in ES, start_src_row: u16,
                   src_stride: u16 in stack, tail_bits: u8 in stack,
                   height: u8 in stack, start_dst_row: u16) {
    u16 src_row = start_src_row;
    u16 dst_row = start_dst_row;
    u8 rows_left = height;

copy_s7_tail_row_loop:
    if (rows_left == 0) {
        return;
    }
    u16 src_off = src_row;
    u16 idx = dst_row;

copy_s7_tail_only:
    const u8 wmask = 0xFF << (8 - tail_bits);
    const u8 tail_lo_mask = wmask >> 7;
    const u8 tail_hi_mask = wmask << 1;
    const u8 tail_byte = [ES:src_off] & wmask;
    const u8 tail_lo = tail_byte >> 7;
    const u8 tail_hi = tail_byte << 1;
    [idx] := ([idx] & ~tail_lo_mask) | tail_lo;
    [idx + 1] := ([idx + 1] & ~tail_hi_mask) | tail_hi;

copy_s7_tail_next_row:
    src_row := src_row + src_stride;
    dst_row := dst_row + LCD_SCAN_STRIDE;
    rows_left := rows_left - 1;
    goto copy_s7_tail_row_loop;
}

fn api fb_copy_s7(src_seg: seg in ES, start_src_row: u16 in AX,
              src_stride: u16 in stack, width: u16 in stack,
              height: u8 in stack, start_dst_row: u16 in BX)
              clobbers(AX, CX, DX, BX, SI, DI, ES, FLAGS) {
    const u16 full_bytes = width >> 3;
    const u8 tail_bits = (width & 0x07) as (u8);

    if (full_bytes != 0) {
        fb_copy_s7_full(src_seg, start_src_row, src_stride,
                        full_bytes, height, start_dst_row);
    }
    if (tail_bits != 0) {
        fb_copy_s7_tail(src_seg, start_src_row + full_bytes, src_stride,
                        tail_bits, height, start_dst_row + full_bytes);
    }
}

u16[8] fb_copy_dispatch = {
    &fb_copy_s0, &fb_copy_s1, &fb_copy_s2, &fb_copy_s3,
    &fb_copy_s4, &fb_copy_s5, &fb_copy_s6, &fb_copy_s7
};

// ---------------------------------------------------------------------------
// API: generic 1bpp blit operations
//
// desc: far pointer to FbBlit. Source rows are MSB-first, with stride
// bytes between rows. Width is in pixels.
// ---------------------------------------------------------------------------

fn api far fb_blit_copy(desc: far32 in ES:SI)
    ds(0x0000) clobbers(AX, CX, DX, BX, SI, DI, ES, FLAGS) {
    const u16 src_row = [ES:SI + FB_BUF_SRC_OFF];
    const u16 src_stride = [ES:SI + FB_BUF_STRIDE];
    const u16 width = [ES:SI + FB_BUF_WIDTH];
    const u8 height = [ES:SI + FB_BUF_HEIGHT];
    const u16 dst_x = [ES:SI + FB_BLIT_DST_X];
    const u8 dst_y = [ES:SI + FB_BLIT_DST_Y];
    const seg src_seg = [ES:SI + FB_BUF_SRC_SEG] as (seg);
    const u16 shift = dst_x & 0x07;
    const u16 dst_row = fb_start_index(dst_x, dst_y);
    const u16 target = fb_copy_dispatch[shift];
    target as fb_copy_s0(src_seg, src_row, src_stride,
                         width, height, dst_row);
}

// ---------------------------------------------------------------------------
// Shift-specialized non-copy blit helpers
// ---------------------------------------------------------------------------

fn fb_copy_inv_s0_full(src_seg: seg in ES, start_src_row: u16,
                   src_stride: u16 in stack, full_bytes: u16 in stack,
                   height: u8 in stack, start_dst_row: u16) {
    u16 src_row = start_src_row;
    u16 dst_row = start_dst_row;
    u8 rows_left = height;

copy_inv_s0_full_row_loop:
    if (rows_left == 0) {
        return;
    }
    u16 src_off = src_row;
    u16 idx = dst_row;
    u16 count = full_bytes;

copy_inv_s0_full_loop:
    const u8 sbyte = [ES:src_off];
    [idx] := ~sbyte;

    src_off := src_off + 1;
    idx := idx + 1;
    count := count - 1;
    if (count != 0) {
        goto copy_inv_s0_full_loop;
    }

copy_inv_s0_full_next_row:
    src_row := src_row + src_stride;
    dst_row := dst_row + LCD_SCAN_STRIDE;
    rows_left := rows_left - 1;
    goto copy_inv_s0_full_row_loop;
}
fn fb_copy_inv_s0_tail(src_seg: seg in ES, start_src_row: u16,
                   src_stride: u16 in stack, tail_bits: u8 in stack,
                   height: u8 in stack, start_dst_row: u16) {
    u16 src_row = start_src_row;
    u16 dst_row = start_dst_row;
    u8 rows_left = height;

copy_inv_s0_tail_row_loop:
    if (rows_left == 0) {
        return;
    }
    u16 src_off = src_row;
    u16 idx = dst_row;

    const u8 wmask = 0xFF << (8 - tail_bits);
    const u8 tail_byte = ~[ES:src_off] & wmask;
    [idx] := ([idx] & ~wmask) | tail_byte;

    src_row := src_row + src_stride;
    dst_row := dst_row + LCD_SCAN_STRIDE;
    rows_left := rows_left - 1;
    goto copy_inv_s0_tail_row_loop;
}
