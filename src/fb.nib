// fb.nib - public 1bpp framebuffer/blitter driver

use "platform.nif";
use "spine.nif";
use "lookup.nif";
use "lcd.nif";

// ---------------------------------------------------------------------------
// API function offsets (pre-multiplied)
// ---------------------------------------------------------------------------

pub const FB_CLEAR         = 0;
pub const FB_BLIT_COPY     = 1;
pub const FB_BLIT_COPY_INV = 2;
pub const FB_BLIT_OR       = 3;
pub const FB_BLIT_XOR      = 4;
pub const FB_BLIT_AND      = 5;
pub const FB_BLIT_NOT      = 6;

const FB_API_SIZE = 0x1C;
const FB_VERSION  = 1;

// ---------------------------------------------------------------------------
// Public buffer descriptors
// ---------------------------------------------------------------------------

pub struct FbBuf {
    far32 src;
    u16 stride;
    u16 width;
    u8 height;
}

pub struct FbBlit {
    struct FbBuf buf;
    u16 dst_x;
    u8 dst_y;
}

pub const FB_BUF_SRC_OFF = 0;
pub const FB_BUF_SRC_SEG = 2;
pub const FB_BUF_STRIDE  = 4;
pub const FB_BUF_WIDTH   = 6;
pub const FB_BUF_HEIGHT  = 8;
pub const FB_BLIT_DST_X  = 9;
pub const FB_BLIT_DST_Y  = 11;

// ---------------------------------------------------------------------------
// API: clear currently selected LCD framebuffer
// ---------------------------------------------------------------------------

fn api far fb_clear() ds(0x0000)
    clobbers(AX, CX, DX, BX, SI, DI, ES, FLAGS) {
    u16 row_base = lcd_fb_offset;
    u8 row = 0;

clear_row_loop:
    if (row >= LCD_HEIGHT_64) {
        return;
    }

    u16 idx = row_base;
    const u16 limit = row_base + LCD_STRIDE;

clear_col_loop:
    if (idx >= limit) {
        row_base := row_base + LCD_SCAN_STRIDE;
        row := row + 1;
        goto clear_row_loop;
    }
    [idx] := 0;
    idx := idx + 1;
    goto clear_col_loop;
}

// ---------------------------------------------------------------------------
// Shared blit setup
// ---------------------------------------------------------------------------

pub fn fb_start_index(x: u16, y: u8) -> u16 {
    return lcd_fb_offset + (zero_extend(y) << 6) + (x >> 3);
}

fn fb_copy_s0_full(src_seg: seg in ES, start_src_row: u16,
                   src_stride: u16 in stack, full_bytes: u16 in stack,
                   height: u8 in stack, start_dst_row: u16) {
    u16 src_row = start_src_row;
    u16 dst_row = start_dst_row;
    u8 rows_left = height;

copy_s0_fast_row_loop:
    if (rows_left == 0) {
        return;
    }
    u16 src_off = src_row;
    u16 idx = dst_row;
    u16 count = full_bytes;

copy_s0_fast_full_loop:
    [idx] := [ES:src_off];
    src_off := src_off + 1;
    idx := idx + 1;
    count := count - 1;
    if (count != 0) {
        goto copy_s0_fast_full_loop;
    }

copy_s0_fast_next_row:
    src_row := src_row + src_stride;
    dst_row := dst_row + LCD_SCAN_STRIDE;
    rows_left := rows_left - 1;
    goto copy_s0_fast_row_loop;
}

fn fb_copy_s0_tail(src_seg: seg in ES, start_src_row: u16,
                   src_stride: u16 in stack, tail_bits: u8 in stack,
                   height: u8 in stack, start_dst_row: u16) {
    u16 src_row = start_src_row;
    u16 dst_row = start_dst_row;
    u8 rows_left = height;

copy_s0_tail_row_loop:
    if (rows_left == 0) {
        return;
    }
    u16 src_off = src_row;
    u16 idx = dst_row;

copy_s0_tail:
    const u8 wmask = 0xFF << (8 - tail_bits);
    const u8 sbyte = [ES:src_off] & wmask;
    [idx] := ([idx] & ~wmask) | sbyte;

copy_s0_next_row:
    src_row := src_row + src_stride;
    dst_row := dst_row + LCD_SCAN_STRIDE;
    rows_left := rows_left - 1;
    goto copy_s0_tail_row_loop;
}

fn api fb_copy_s0(src_seg: seg in ES, start_src_row: u16 in AX,
              src_stride: u16 in stack, width: u16 in stack,
              height: u8 in stack, start_dst_row: u16 in BX)
              clobbers(AX, CX, DX, BX, SI, DI, ES, FLAGS) {
    const u16 full_bytes = width >> 3;
    const u8 tail_bits = (width & 0x07) as (u8);

    if (full_bytes != 0) {
        fb_copy_s0_full(src_seg, start_src_row, src_stride,
                        full_bytes, height, start_dst_row);
    }
    if (tail_bits != 0) {
        fb_copy_s0_tail(src_seg, start_src_row + full_bytes, src_stride,
                        tail_bits, height, start_dst_row + full_bytes);
    }
}

fn fb_copy_s1_full(src_seg: seg in ES, start_src_row: u16,
                   src_stride: u16 in stack, full_bytes: u16 in stack,
                   height: u8 in stack, start_dst_row: u16) {
    u16 src_row = start_src_row;
    u16 dst_row = start_dst_row;
    u8 rows_left = height;

copy_s1_full_row_loop:
    if (rows_left == 0) {
        return;
    }
    u16 src_off = src_row;
    u16 idx = dst_row;
    u16 count = full_bytes;

copy_s1_full_loop:
    const u8 sbyte = [ES:src_off];
    const u8 src_lo = sbyte >> 1;
    const u8 src_hi = sbyte << 7;
    [idx] := ([idx] & 0x80) | src_lo;
    [idx + 1] := ([idx + 1] & 0x7F) | src_hi;
    src_off := src_off + 1;
    idx := idx + 1;
    count := count - 1;
    if (count != 0) {
        goto copy_s1_full_loop;
    }

copy_s1_full_next_row:
    src_row := src_row + src_stride;
    dst_row := dst_row + LCD_SCAN_STRIDE;
    rows_left := rows_left - 1;
    goto copy_s1_full_row_loop;
}

fn fb_copy_s1_tail(src_seg: seg in ES, start_src_row: u16,
                   src_stride: u16 in stack, tail_bits: u8 in stack,
                   height: u8 in stack, start_dst_row: u16) {
    u16 src_row = start_src_row;
    u16 dst_row = start_dst_row;
    u8 rows_left = height;

copy_s1_tail_row_loop:
    if (rows_left == 0) {
        return;
    }
    u16 src_off = src_row;
    u16 idx = dst_row;

copy_s1_tail:
    const u8 wmask = 0xFF << (8 - tail_bits);
    const u8 tail_lo_mask = wmask >> 1;
    const u8 tail_hi_mask = wmask << 7;
    const u8 tail_byte = [ES:src_off] & wmask;
    const u8 tail_lo = tail_byte >> 1;
    const u8 tail_hi = tail_byte << 7;
    [idx] := ([idx] & ~tail_lo_mask) | tail_lo;
    [idx + 1] := ([idx + 1] & ~tail_hi_mask) | tail_hi;

copy_s1_next_row:
    src_row := src_row + src_stride;
    dst_row := dst_row + LCD_SCAN_STRIDE;
    rows_left := rows_left - 1;
    goto copy_s1_tail_row_loop;
}

fn api fb_copy_s1(src_seg: seg in ES, start_src_row: u16 in AX,
              src_stride: u16 in stack, width: u16 in stack,
              height: u8 in stack, start_dst_row: u16 in BX)
              clobbers(AX, CX, DX, BX, SI, DI, ES, FLAGS) {
    const u16 full_bytes = width >> 3;
    const u8 tail_bits = (width & 0x07) as (u8);

    if (full_bytes != 0) {
        fb_copy_s1_full(src_seg, start_src_row, src_stride,
                        full_bytes, height, start_dst_row);
    }
    if (tail_bits != 0) {
        fb_copy_s1_tail(src_seg, start_src_row + full_bytes, src_stride,
                        tail_bits, height, start_dst_row + full_bytes);
    }
}

