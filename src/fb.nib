    u16 src_off = src_row;
    u16 idx = dst_row;
    u16 count = full_bytes;

copy_s6_fast_full_loop:
    const u8 sbyte = [ES:src_off];
    const u8 src_lo = sbyte >> 6;
    const u8 src_hi = sbyte << 2;
    [idx] := ([idx] & 0xFC) | src_lo;
    [idx + 1] := ([idx + 1] & 0x03) | src_hi;
    src_off := src_off + 1;
    idx := idx + 1;
