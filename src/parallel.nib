// parallel.nib — Centronics parallel port driver
//
// Drives the gate array's parallel output: data latch at port 0x40,
// strobe via the control latch at port 0x30, busy status read from
// port 0xA0, and ACK via IRQ FE.

use "platform.nif";
use "spine.nif";
use "lookup.nif";
use "control.nif";
use "irq.nif";
use "status.nif";

// ---------------------------------------------------------------------------
// API function offsets (pre-multiplied)
// ---------------------------------------------------------------------------

pub const PAR_WRITE = 0;  // write byte (AL = data)
pub const PAR_READY = 1;  // check ready (CF=0 ready, CF=1 busy)

const PAR_API_SIZE = 0x08;  // 2 entries × 4 bytes
const PAR_VERSION  = 1;

// ---------------------------------------------------------------------------
// State
// ---------------------------------------------------------------------------

at(0x0000:0x070B);
u8 parallel_acked;
end at;

// ---------------------------------------------------------------------------
// IRQ FE — Centronics ACK
// ---------------------------------------------------------------------------

fn interrupt ack_handler() ds(0x0000) {
    parallel_acked := 1;
    irq_ack(IRQCLR_FE);
}

fn parallel_wait_ready() ds(none) {
ready_loop:
    if (gate_status_centronics_busy() == 0) {
        return;
    }
    goto ready_loop;
}

// ---------------------------------------------------------------------------
// API functions
// ---------------------------------------------------------------------------

fn api far write(data: u8 in AL) ds(0x0000) clobbers(FLAGS) {
    parallel_wait_ready();
    parallel_acked := 0;
    irq_ack(IRQCLR_FE);

    // Latch data byte
    port_out(PORT_CENTRONICS, data);

    // Pulse -STB through the shared control latch.
    control_pulse_low(CTRL_CENTRONICS_STB);

ack_loop:
    if (parallel_acked != 0) {
        return;
    }
    halt();
    goto ack_loop;
}

fn api far ready() -> u8 in AL ds(none) clobbers(FLAGS) {
    const u8 val = gate_status_centronics_busy();
    if (val != 0) {
        CF := 1;
    } else {
        CF := 0;
    }
    return val;
}

// ---------------------------------------------------------------------------
// Jump table (must follow function definitions)
// ---------------------------------------------------------------------------

pub far32[2] parallel_table = {@write, @ready};

// ---------------------------------------------------------------------------
// Init
// ---------------------------------------------------------------------------

pub fn parallel_init() {
    parallel_acked := 0;

    // Idle the data latch
    port_out(PORT_CENTRONICS, 0xFF);
    irq_install(IRQ_VEC_FE, ack_handler, IRQ_FE, IRQCLR_FE);

    // Register with service locator
    register(DEV_PARALLEL, PAR_VERSION, @parallel_table, PAR_API_SIZE);
}
